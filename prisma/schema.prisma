generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Bảng Ingredient (Dữ liệu nguyên liệu gốc - read-only, seed từ trước)
model Ingredient {
  id       String @id @default(uuid())
  name     String
  calories Int
  protein  Float
  carbs    Float
  fat      Float
}
